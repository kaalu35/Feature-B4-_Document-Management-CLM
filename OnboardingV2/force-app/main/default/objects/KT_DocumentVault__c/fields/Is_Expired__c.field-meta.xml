<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Is_Expired__c</fullName>
    <description>True when the vault entry has an expiry date in the past.</description>
    <formula>AND(NOT(ISBLANK(Expiry_Date__c)), TODAY() &gt; Expiry_Date__c)</formula>
    <formulaTreatBlanksAs>BlankAsBlank</formulaTreatBlanksAs>
    <label>Is Expired</label>
    <trackHistory>false</trackHistory>
    <type>Checkbox</type>
</CustomField>
