public with sharing class KT_AuditExportService {
    private static final Integer MAX_PDF_LINES = 52;
    private static final Integer MAX_PDF_LINE_LENGTH = 90;

    public class AuditExportResult {
        @AuraEnabled @InvocableVariable public Id onboardingId;
        @AuraEnabled @InvocableVariable public Id contentVersionId;
        @AuraEnabled @InvocableVariable public Id contentDocumentId;
        @AuraEnabled @InvocableVariable public Id vaultEntryId;
        @AuraEnabled @InvocableVariable public String certificationHash;
        @AuraEnabled @InvocableVariable public Datetime exportedAt;
        @AuraEnabled @InvocableVariable public Integer documentCount;
        @AuraEnabled @InvocableVariable public Integer signatureAuditCount;
        @AuraEnabled @InvocableVariable public Integer ocrJobCount;
        @AuraEnabled @InvocableVariable public String message;
    }

    public class AuditExportRequest {
        @InvocableVariable(required=true) public Id onboardingId;
    }

    @AuraEnabled
    public static AuditExportResult exportAuditPackage(Id onboardingId) {
        if (onboardingId == null) {
            throw new AuraHandledException('onboardingId is required.');
        }

        ExportContext context = buildContext(onboardingId);
        String reportBody = renderReport(context);
        String hashValue = generateCertificationHash(reportBody);
        String certifiedBody = reportBody
            + '\nCertification Footer'
            + '\nExported At UTC: ' + String.valueOf(context.exportedAt)
            + '\nCertification Hash: ' + hashValue
            + '\nGenerated By User Id: ' + UserInfo.getUserId();

        ContentVersion version = new ContentVersion(
            Title = 'KT Audit Export ' + Date.today().format(),
            PathOnClient = 'kt-audit-export-' + String.valueOf(Date.today()) + '.pdf',
            VersionData = Blob.valueOf(renderSimplePdf(certifiedBody))
        );
        insert version;

        ContentVersion insertedVersion = [
            SELECT Id, ContentDocumentId
            FROM ContentVersion
            WHERE Id = :version.Id
            LIMIT 1
        ];

        KT_DocumentVault__c exportVault = new KT_DocumentVault__c(
            KT_Onboarding__c = onboardingId,
            Document_Name__c = 'Certified Audit Export ' + String.valueOf(Date.today()),
            Content_Document_Id__c = insertedVersion.ContentDocumentId,
            Document_Type__c = 'Compliance Record',
            Status__c = 'Verified',
            OCR_Status__c = 'Not Required',
            Signature_Status__c = 'Not Required',
            Version_Number__c = 1,
            Uploaded_By__c = UserInfo.getUserId(),
            Upload_Timestamp__c = System.now(),
            Regulatory_Tag__c = 'Audit Export'
        );
        insert exportVault;

        AuditExportResult result = new AuditExportResult();
        result.onboardingId = onboardingId;
        result.contentVersionId = insertedVersion.Id;
        result.contentDocumentId = insertedVersion.ContentDocumentId;
        result.vaultEntryId = exportVault.Id;
        result.certificationHash = hashValue;
        result.exportedAt = context.exportedAt;
        result.documentCount = context.vaultEntries.size();
        result.signatureAuditCount = context.signatureAudits.size();
        result.ocrJobCount = context.ocrJobs.size();
        result.message = 'Certified audit export generated.';
        return result;
    }

    @InvocableMethod(
        label='Generate KT Audit Export'
        description='Generates a certified PDF audit package for an onboarding document vault.'
    )
    public static List<AuditExportResult> generateAuditExports(List<AuditExportRequest> requests) {
        List<AuditExportResult> results = new List<AuditExportResult>();
        if (requests == null) {
            return results;
        }

        for (AuditExportRequest request : requests) {
            if (request == null || request.onboardingId == null) {
                AuditExportResult result = new AuditExportResult();
                result.message = 'onboardingId is required.';
                results.add(result);
                continue;
            }
            results.add(exportAuditPackage(request.onboardingId));
        }
        return results;
    }

    @TestVisible
    private static String generateCertificationHash(String reportBody) {
        return EncodingUtil.convertToHex(
            Crypto.generateDigest('SHA-256', Blob.valueOf(reportBody + '|' + UserInfo.getOrganizationId()))
        );
    }

    private static ExportContext buildContext(Id onboardingId) {
        ExportContext context = new ExportContext();
        context.onboardingId = onboardingId;
        context.exportedAt = System.now();

        context.vaultEntries = [
            SELECT Id, Document_Name__c, Content_Document_Id__c, Document_Type__c, Status__c,
                   Expiry_Date__c, OCR_Status__c, Version_Number__c, Signature_Status__c,
                   Regulatory_Tag__c, Upload_Timestamp__c, Uploaded_By__r.Name
            FROM KT_DocumentVault__c
            WHERE KT_Onboarding__c = :onboardingId
            ORDER BY Document_Type__c ASC, Document_Name__c ASC, CreatedDate ASC
        ];

        Set<Id> contentDocumentIds = new Set<Id>();
        Set<Id> vaultIds = new Set<Id>();
        for (KT_DocumentVault__c vaultEntry : context.vaultEntries) {
            vaultIds.add(vaultEntry.Id);
            if (!String.isBlank(vaultEntry.Content_Document_Id__c)) {
                contentDocumentIds.add((Id) vaultEntry.Content_Document_Id__c);
            }
        }

        context.versionsByContentDocumentId = new Map<Id, List<ContentVersion>>();
        if (!contentDocumentIds.isEmpty()) {
            for (ContentVersion version : [
                SELECT Id, ContentDocumentId, Title, VersionNumber, CreatedDate, CreatedBy.Name, FileType, ContentSize
                FROM ContentVersion
                WHERE ContentDocumentId IN :contentDocumentIds
                ORDER BY ContentDocumentId ASC, VersionNumber DESC
            ]) {
                if (!context.versionsByContentDocumentId.containsKey(version.ContentDocumentId)) {
                    context.versionsByContentDocumentId.put(version.ContentDocumentId, new List<ContentVersion>());
                }
                context.versionsByContentDocumentId.get(version.ContentDocumentId).add(version);
            }
        }

        context.ocrJobs = [
            SELECT Id, KT_DocumentVault__c, OCR_Provider__c, Job_Id__c, Status__c,
                   Document_Type_Detected__c, Confidence_Score__c, Reviewed_By__r.Name,
                   Reviewed_At__c, Retry_Count__c
            FROM KT_OCR_Job__c
            WHERE KT_Onboarding__c = :onboardingId
            ORDER BY CreatedDate ASC
        ];

        context.signatureRequests = [
            SELECT Id, KT_DocumentVault__c, Signing_Provider__c, Status__c, Signing_Order__c,
                   Total_Signers__c, Completed_Signers__c, Expiry_Date__c, External_Envelope_Id__c,
                   Completed_Document_Id__c
            FROM KT_Signature_Request__c
            WHERE KT_Onboarding__c = :onboardingId
            ORDER BY CreatedDate ASC
        ];

        Set<Id> signatureRequestIds = new Set<Id>();
        for (KT_Signature_Request__c signatureRequest : context.signatureRequests) {
            signatureRequestIds.add(signatureRequest.Id);
        }

        context.signersByRequestId = new Map<Id, List<KT_Signer__c>>();
        context.signatureAudits = new List<KT_Signature_Audit__c>();
        if (!signatureRequestIds.isEmpty()) {
            for (KT_Signer__c signer : [
                SELECT Id, KT_Signature_Request__c, Signer_Name__c, Signer_Email__c,
                       Signer_Role__c, Signing_Order__c, Status__c, Signed_At__c,
                       Delegated_To__c, Delegation_Reason__c
                FROM KT_Signer__c
                WHERE KT_Signature_Request__c IN :signatureRequestIds
                ORDER BY KT_Signature_Request__c ASC, Signing_Order__c ASC, CreatedDate ASC
            ]) {
                if (!context.signersByRequestId.containsKey(signer.KT_Signature_Request__c)) {
                    context.signersByRequestId.put(signer.KT_Signature_Request__c, new List<KT_Signer__c>());
                }
                context.signersByRequestId.get(signer.KT_Signature_Request__c).add(signer);
            }

            context.signatureAudits = [
                SELECT Id, KT_Signature_Request__c, KT_Signer__c, Event_Type__c, Event_Timestamp__c,
                       IP_Address__c, Device_User_Agent__c, Hash_Value__c, Session_Token__c
                FROM KT_Signature_Audit__c
                WHERE KT_Signature_Request__c IN :signatureRequestIds
                ORDER BY Event_Timestamp__c ASC, CreatedDate ASC
            ];
        }

        return context;
    }

    private static String renderReport(ExportContext context) {
        List<String> lines = new List<String>();
        lines.add('KT Certified Document Audit Package');
        lines.add('Onboarding Id: ' + String.valueOf(context.onboardingId));
        lines.add('Export Timestamp UTC: ' + String.valueOf(context.exportedAt));
        lines.add('Documents: ' + String.valueOf(context.vaultEntries.size()));
        lines.add('Signature Requests: ' + String.valueOf(context.signatureRequests.size()));
        lines.add('Signature Audit Events: ' + String.valueOf(context.signatureAudits.size()));
        lines.add('OCR Jobs: ' + String.valueOf(context.ocrJobs.size()));
        lines.add('');
        lines.add('Document Vault Evidence');

        for (KT_DocumentVault__c vaultEntry : context.vaultEntries) {
            lines.add('- ' + safe(vaultEntry.Document_Name__c, 'Document')
                + ' | Type=' + safe(vaultEntry.Document_Type__c, 'N/A')
                + ' | Status=' + safe(vaultEntry.Status__c, 'N/A')
                + ' | OCR=' + safe(vaultEntry.OCR_Status__c, 'N/A')
                + ' | Signature=' + safe(vaultEntry.Signature_Status__c, 'N/A')
                + ' | Regulatory=' + safe(vaultEntry.Regulatory_Tag__c, 'N/A'));

            Id contentDocumentId = String.isBlank(vaultEntry.Content_Document_Id__c)
                ? null
                : (Id) vaultEntry.Content_Document_Id__c;
            List<ContentVersion> versions = contentDocumentId == null
                ? new List<ContentVersion>()
                : context.versionsByContentDocumentId.get(contentDocumentId);
            if (versions == null || versions.isEmpty()) {
                lines.add('  Version History: no Salesforce File versions linked.');
            } else {
                for (ContentVersion version : versions) {
                    lines.add('  Version ' + version.VersionNumber
                        + ' | Title=' + safe(version.Title, 'N/A')
                        + ' | Type=' + safe(version.FileType, 'N/A')
                        + ' | Size=' + String.valueOf(version.ContentSize)
                        + ' | Created=' + String.valueOf(version.CreatedDate)
                        + ' | By=' + (version.CreatedBy == null ? 'N/A' : safe(version.CreatedBy.Name, 'N/A')));
                }
            }
        }

        lines.add('');
        lines.add('Signature Evidence');
        for (KT_Signature_Request__c signatureRequest : context.signatureRequests) {
            lines.add('- Request ' + signatureRequest.Id
                + ' | Provider=' + safe(signatureRequest.Signing_Provider__c, 'N/A')
                + ' | Status=' + safe(signatureRequest.Status__c, 'N/A')
                + ' | Completed=' + String.valueOf(signatureRequest.Completed_Signers__c)
                + '/' + String.valueOf(signatureRequest.Total_Signers__c));
            List<KT_Signer__c> signers = context.signersByRequestId.get(signatureRequest.Id);
            if (signers != null) {
                for (KT_Signer__c signer : signers) {
                    lines.add('  Signer ' + safe(signer.Signer_Name__c, 'N/A')
                        + ' <' + safe(signer.Signer_Email__c, 'N/A') + '>'
                        + ' | Role=' + safe(signer.Signer_Role__c, 'N/A')
                        + ' | Status=' + safe(signer.Status__c, 'N/A')
                        + ' | Signed=' + String.valueOf(signer.Signed_At__c));
                }
            }
        }
        for (KT_Signature_Audit__c audit : context.signatureAudits) {
            lines.add('  Audit ' + safe(audit.Event_Type__c, 'Event')
                + ' | At=' + String.valueOf(audit.Event_Timestamp__c)
                + ' | IP=' + safe(audit.IP_Address__c, 'N/A')
                + ' | Hash=' + safe(audit.Hash_Value__c, 'N/A'));
        }

        lines.add('');
        lines.add('OCR Evidence');
        for (KT_OCR_Job__c ocrJob : context.ocrJobs) {
            lines.add('- OCR Job ' + ocrJob.Id
                + ' | Provider=' + safe(ocrJob.OCR_Provider__c, 'N/A')
                + ' | Status=' + safe(ocrJob.Status__c, 'N/A')
                + ' | Type=' + safe(ocrJob.Document_Type_Detected__c, 'N/A')
                + ' | Confidence=' + String.valueOf(ocrJob.Confidence_Score__c)
                + ' | Reviewed=' + String.valueOf(ocrJob.Reviewed_At__c)
                + ' | Reviewer=' + (ocrJob.Reviewed_By__r == null ? 'N/A' : safe(ocrJob.Reviewed_By__r.Name, 'N/A')));
        }

        return String.join(lines, '\n');
    }

    private static String renderSimplePdf(String source) {
        List<String> pdfLines = buildPdfLines(source);
        String contentStream = 'BT\n/F1 11 Tf\n14 TL\n50 742 Td\n';
        for (String line : pdfLines) {
            contentStream += '(' + escapePdfText(line) + ') Tj\nT*\n';
        }
        contentStream += 'ET\n';

        List<String> objects = new List<String>{
            '<< /Type /Catalog /Pages 2 0 R >>',
            '<< /Type /Pages /Kids [3 0 R] /Count 1 >>',
            '<< /Type /Page /Parent 2 0 R /MediaBox [0 0 612 792] /Resources << /Font << /F1 4 0 R >> >> /Contents 5 0 R >>',
            '<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica >>',
            '<< /Length ' + contentStream.length() + ' >>\nstream\n' + contentStream + 'endstream'
        };

        String pdf = '%PDF-1.4\n';
        List<Integer> offsets = new List<Integer>();
        for (Integer index = 0; index < objects.size(); index++) {
            offsets.add(pdf.length());
            pdf += String.valueOf(index + 1) + ' 0 obj\n' + objects[index] + '\nendobj\n';
        }

        Integer xrefOffset = pdf.length();
        pdf += 'xref\n0 ' + String.valueOf(objects.size() + 1) + '\n';
        pdf += '0000000000 65535 f \n';
        for (Integer offset : offsets) {
            pdf += String.valueOf(offset).leftPad(10, '0') + ' 00000 n \n';
        }
        pdf += 'trailer\n<< /Root 1 0 R /Size ' + String.valueOf(objects.size() + 1) + ' >>\n';
        pdf += 'startxref\n' + String.valueOf(xrefOffset) + '\n%%EOF';
        return pdf;
    }

    private static List<String> buildPdfLines(String source) {
        String normalized = String.isBlank(source) ? '' : source.replace('\r\n', '\n').replace('\r', '\n');
        List<String> lines = new List<String>();
        for (String rawLine : normalized.split('\n')) {
            addWrappedPdfLine(lines, rawLine);
            if (lines.size() >= MAX_PDF_LINES) {
                break;
            }
        }
        if (lines.isEmpty()) {
            lines.add('');
        }
        return lines;
    }

    private static void addWrappedPdfLine(List<String> lines, String rawLine) {
        String remaining = rawLine == null ? '' : rawLine.replace('\t', ' ');
        if (remaining.length() == 0) {
            lines.add('');
            return;
        }

        while (remaining.length() > MAX_PDF_LINE_LENGTH && lines.size() < MAX_PDF_LINES) {
            lines.add(remaining.substring(0, MAX_PDF_LINE_LENGTH));
            remaining = remaining.substring(MAX_PDF_LINE_LENGTH);
        }
        if (lines.size() < MAX_PDF_LINES) {
            lines.add(remaining);
        }
    }

    private static String escapePdfText(String value) {
        return (value == null ? '' : value)
            .replace('\\', '\\\\')
            .replace('(', '\\(')
            .replace(')', '\\)');
    }

    private static String safe(String value, String fallback) {
        return String.isBlank(value) ? fallback : value;
    }

    private class ExportContext {
        Id onboardingId;
        Datetime exportedAt;
        List<KT_DocumentVault__c> vaultEntries = new List<KT_DocumentVault__c>();
        Map<Id, List<ContentVersion>> versionsByContentDocumentId = new Map<Id, List<ContentVersion>>();
        List<KT_OCR_Job__c> ocrJobs = new List<KT_OCR_Job__c>();
        List<KT_Signature_Request__c> signatureRequests = new List<KT_Signature_Request__c>();
        Map<Id, List<KT_Signer__c>> signersByRequestId = new Map<Id, List<KT_Signer__c>>();
        List<KT_Signature_Audit__c> signatureAudits = new List<KT_Signature_Audit__c>();
    }
}
